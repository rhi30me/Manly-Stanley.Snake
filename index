class Particle:
    def __init__(self, x, y, color):
        self.x  = x
        self.y  = y
        self.vx = random.uniform(-3, 3)
        self.vy = random.uniform(-3, 3)
        self.color = color
        self.life  = random.randint(20, 40)
        self.max_life = self.life
        self.r = random.randint(3, 7)

    def update(self):
        self.x   += self.vx
        self.y   += self.vy
        self.vy  += 0.15
        self.life -= 1

    def draw(self, surface):
        alpha = self.life / self.max_life
        r, g, b = self.color
        col = (int(r * alpha), int(g * alpha), int(b * alpha))
        pygame.draw.circle(surface, col, (int(self.x), int(self.y)), self.r)


particles = []

def spawn_particles(gx, gy, color, n=20):
    cx = gx * CELL + CELL // 2
    cy = gy * CELL + CELL // 2
    for _ in range(n):
        particles.append(Particle(cx, cy, color))


