def new_game():
    snake     = [(COLS // 2, ROWS // 2)]
    direction = (1, 0)
    next_dir  = (1, 0)
    score     = 0
    food, food_color = spawn_food(snake)
    return snake, direction, next_dir, score, food, food_color


def spawn_food(snake):
    while True:
        pos = (random.randint(0, COLS - 1), random.randint(0, ROWS - 1))
        if pos not in snake:
            return pos, random.choice(FOOD_COLORS)



def draw_start_screen(tick, hi):
    screen.fill(DARK_GRAY)
    draw_grid()

    # fun goofy mf title screen so mf manly
    title = "MANLY STANLEY"
    total = len(title)
    x_off = WIDTH // 2 - (total * 38) // 2
    for i, ch in enumerate(title):
        wave_y = int(20 * math.sin(tick * 0.07 + i * 0.5))
        col    = rainbow_color(i, total)
        surf   = font_big.render(ch, True, col)
        screen.blit(surf, (x_off + i * 38, 130 + wave_y))

    show_text_centered(screen, "Use ARROW KEYS or WASD to move",
                       font_small, (180, 180, 200), 260)
    show_text_centered(screen, "Eat food to grow — don't hit walls or yourself!",
                       font_small, (180, 180, 200), 290)

    if hi > 0:
        show_text_centered(screen, f"Best: {hi}", font_med, (255, 220, 80), 340)

    blink_col = RAINBOW[int(tick / 15) % len(RAINBOW)]
    show_text_centered(screen, "Press SPACE to Play", font_med, blink_col, 410)


def draw_game_over(score, hi, tick):
    overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
    overlay.fill((0, 0, 0, 160))
    screen.blit(overlay, (0, 0))

    show_text_centered(screen, "GAME OVER", font_big, (255, 60, 60), 180)
    show_text_centered(screen, f"Score: {score}", font_med, WHITE, 280)
    if score >= hi:
        show_text_centered(screen, "🎉 New Best!", font_med, (255, 220, 50), 320)
    else:
        show_text_centered(screen, f"Best: {hi}", font_med, (200, 200, 200), 320)

    blink_col = RAINBOW[int(tick / 15) % len(RAINBOW)]
    show_text_centered(screen, "SPACE to restart  |  Q to quit",
                       font_med, blink_col, 390)


# ── main loop ─────────────────────────────────────────────────────────────────

def main():
    state = "start"   # "start" | "play" | "dead"
    snake, direction, next_dir, score, food, food_color = new_game()
    hi_score = 0
    tick = 0

    while True:
        clock.tick(FPS)
        tick += 1

        # ── events ──
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit(); sys.exit()

            if event.type == pygame.KEYDOWN:
                # quit anytime
                if event.key == pygame.K_q:
                    pygame.quit(); sys.exit()

                # start / re
                if event.key == pygame.K_SPACE:
                    if state in ("start", "dead"):
                        snake, direction, next_dir, score, food, food_color = new_game()
                        particles.clear()
                        state = "play"

                # dir input (prevent 180°)
                if state == "play":
                    if event.key in (pygame.K_UP, pygame.K_w) and direction != (0, 1):
                        next_dir = (0, -1)
                    elif event.key in (pygame.K_DOWN, pygame.K_s) and direction != (0, -1):
                        next_dir = (0, 1)
                    elif event.key in (pygame.K_LEFT, pygame.K_a) and direction != (1, 0):
                        next_dir = (-1, 0)
                    elif event.key in (pygame.K_RIGHT, pygame.K_d) and direction != (-1, 0):
                        next_dir = (1, 0)

        # ── update particles always ──
        for p in particles:
            p.update()
        particles[:] = [p for p in particles if p.life > 0]

        # ── game logic ──
        if state == "play":
            direction = next_dir
            hx, hy    = snake[0]
            new_head  = (hx + direction[0], hy + direction[1])

            # wall collision
            if not (0 <= new_head[0] < COLS and 0 <= new_head[1] < ROWS):
                hi_score = max(hi_score, score)
                spawn_particles(hx, hy, (255, 80, 80), 40)
                state = "dead"
            # self collision
            elif new_head in snake:
                hi_score = max(hi_score, score)
                spawn_particles(hx, hy, (255, 80, 80), 40)
                state = "dead"
            else:
                snake.insert(0, new_head)
                if new_head == food:
                    score += 1
                    food, food_color = spawn_food(snake)
                else:
                    snake.pop()

        # ── draw ──
        screen.fill(DARK_GRAY)
        draw_grid()

        if state == "start":
            draw_start_screen(tick, hi_score)
        else:
            # draw food
            draw_food(screen, food[0], food[1], food_color, tick)

            total = len(snake)
            for i, (sx, sy) in enumerate(snake):
                col = rainbow_color(i, total)
                draw_rounded_cell(screen, col, sx, sy)

            if snake:
                draw_eyes(screen, snake[0], direction)

            # particles
            for p in particles:
                p.draw(screen)

            
            score_surf = font_med.render(f"Score: {score}  Best: {hi_score}",
                                         True, WHITE)
            screen.blit(score_surf, (10, 8))

            speed_surf = font_small.render(
                f"Speed: {min(score // 5 + 1, 5)}x", True, (150, 150, 180))
            screen.blit(speed_surf, (WIDTH - 110, 12))

            if state == "dead":
                draw_game_over(score, hi_score, tick)

        pygame.display.flip()

        # accelerrerate !!! ! ! ! ! ! ! !  adderall snake
        if state == "play":
            clock.tick(FPS + min(score // 5, 8))


if __name__ == "__main__":
    main()
