import pygame
import random
import math
import sys

pygame.init()

WIDTH, HEIGHT = 800, 600
CELL = 20
COLS = WIDTH // CELL
ROWS = HEIGHT // CELL
FPS = 12

BLACK      = (0, 0, 0)
WHITE      = (255, 255, 255)
DARK_GRAY  = (20, 20, 30)
GRID_COLOR = (30, 30, 45)

RAINBOW = [
    (255, 80,  80),
    (255, 160, 60),
    (255, 230, 60),
    (80,  220, 80),
    (60,  180, 255),
    (150, 80,  255),
    (255, 80,  200),
]

FOOD_COLORS = [
    (255, 50,  50),
    (255, 165, 0),
    (255, 255, 0),
    (50,  255, 50),
    (0,   200, 255),
    (200, 50,  255),
    (255, 50,  150),
    (255, 255, 255),
]

# Screen setup
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("🐍 Manly Stanley")
clock = pygame.time.Clock()

# Fonts
font_big   = pygame.font.SysFont("Arial", 64, bold=True)
font_med   = pygame.font.SysFont("Arial", 32, bold=True)
font_small = pygame.font.SysFont("Arial", 22)



def draw_grid():
    for x in range(0, WIDTH, CELL):
        pygame.draw.line(screen, GRID_COLOR, (x, 0), (x, HEIGHT))
    for y in range(0, HEIGHT, CELL):
        pygame.draw.line(screen, GRID_COLOR, (0, y), (WIDTH, y))


def lerp_color(c1, c2, t):
    return tuple(int(c1[i] + (c2[i] - c1[i]) * t) for i in range(3))


def rainbow_color(index, total):
    """Smoothly cycle through RAINBOW palette based on position."""
    if total <= 1:
        return RAINBOW[0]
    t      = (index / total) * len(RAINBOW)
    idx    = int(t) % len(RAINBOW)
    frac   = t - int(t)
    return lerp_color(RAINBOW[idx], RAINBOW[(idx + 1) % len(RAINBOW)], frac)


def draw_rounded_cell(surface, color, gx, gy, radius=6):
    rect = pygame.Rect(gx * CELL + 1, gy * CELL + 1, CELL - 2, CELL - 2)
    pygame.draw.rect(surface, color, rect, border_radius=radius)
    # highlight
    hi = tuple(min(255, c + 60) for c in color)
    pygame.draw.rect(surface, hi, rect, width=2, border_radius=radius)


def draw_food(surface, fx, fy, color, tick):
    """Pulsing star-shaped food."""
    cx = fx * CELL + CELL // 2
    cy = fy * CELL + CELL // 2
    pulse = 1 + 0.15 * math.sin(tick * 0.15)
    r_out = int(CELL * 0.45 * pulse)
    r_in  = int(CELL * 0.20 * pulse)
    points = []
    for i in range(10):
        angle  = math.radians(i * 36 - 90)
        radius = r_out if i % 2 == 0 else r_in
        points.append((cx + radius * math.cos(angle),
                       cy + radius * math.sin(angle)))
    pygame.draw.polygon(surface, color, points)
    glow = tuple(min(255, c + 80) for c in color)
    pygame.draw.polygon(surface, glow, points, 2)


def draw_eyes(surface, head, direction):
    hx = head[0] * CELL + CELL // 2
    hy = head[1] * CELL + CELL // 2
    dx, dy = direction
    perp = (-dy, dx)
    for sign in (+1, -1):
        ex = hx + dx * 4 + perp[0] * 4 * sign
        ey = hy + dy * 4 + perp[1] * 4 * sign
        pygame.draw.circle(surface, WHITE, (int(ex), int(ey)), 3)
        pygame.draw.circle(surface, BLACK, (int(ex + dx), int(ey + dy)), 2)


def show_text_centered(surface, text, font, color, y):
    surf = font.render(text, True, color)
    x = (WIDTH - surf.get_width()) // 2
    surface.blit(surf, (x, y))


def glow_text(surface, text, font, color, y, tick):
    alpha = int(180 + 75 * math.sin(tick * 0.08))
    glow  = tuple(min(255, c + 60) for c in color[:3])
    show_text_centered(surface, text, font, glow + (alpha,), y)
    show_text_centered(surface, text, font, color, y)


